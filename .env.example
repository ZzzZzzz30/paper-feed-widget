# ===========================================
# PaperFeed 环境变量配置模板
# 复制此文件为 .env.local 并填入真实密钥
# .env.local 已被 .gitignore 忽略，不会上传到 GitHub
# ===========================================

# 腾讯云机器翻译（推荐，每月500万字符免费）
TENCENT_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云机器翻译（备用，每月100万字符免费）
ALIYUN_ACCESS_KEY_ID=LTAIxxxxxxxxxxxxxxxx
ALIYUN_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Elsevier ScienceDirect API
ELSEVIER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API（AI 分析功能）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
